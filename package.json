{
  "name": "locus-learning-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,green \"vite\" \"tsx watch server/index.ts\"",
    "build": "npm run typecheck && vite build",
    "build:server": "esbuild server/index.ts server/migrate-cli.ts server/admin.ts --bundle --platform=node --format=esm --packages=external --outdir=build/server --out-extension:.js=.mjs",
    "build:production": "npm run build && npm run build:server",
    "start": "tsx server/index.ts",
    "start:production": "node build/server/index.mjs",
    "db:migrate": "tsx server/migrate-cli.ts",
    "admin": "tsx server/admin.ts",
    "typecheck": "tsc --noEmit",
    "test:hosted": "node scripts/test/hosted-integration.mjs",
    "test:assistant-edits": "tsx scripts/test/assistant-edit-variants.ts",
    "test:share-flattening": "tsx scripts/test/share-flattening.ts",
    "test:social-meta": "tsx scripts/test/social-meta.ts",
    "test:source-edit-selection": "tsx scripts/test/source-edit-selection.ts",
    "test:study-tools": "tsx scripts/test/study-tools.ts",
    "test:access": "node scripts/test/access-control.mjs",
    "metapost:build": "docker build -t locus-metapost:1 docker/metapost",
    "metapost:check": "docker image inspect locus-metapost:1 >/dev/null",
    "pdf:build": "docker build -t locus-pdf2markdown:local docker/pdf2markdown",
    "pdf:up": "docker compose -f compose.pdf.yaml up -d --build",
    "pdf:down": "docker compose -f compose.pdf.yaml down"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "better-auth": "^1.6.23",
    "diff-match-patch": "^1.0.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "katex": "^0.16.22",
    "lucide-react": "^0.468.0",
    "openai": "^6.47.0",
    "pg": "^8.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/diff-match-patch": "^1.0.36",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
